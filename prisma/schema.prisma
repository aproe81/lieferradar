generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Entry {
  id        String   @id @default(cuid())
  name      String
  author    String
  note      String?  @db.Text
  rating    Int
  orderDate DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
